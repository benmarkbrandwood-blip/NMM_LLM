# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / type / lint caches and local temp workspaces
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tmp/
.tmp-pytest/

# Rust build artefacts (repo-root or native crate)
/target/
native/target/

# IDE / editor lock files
.~lock.*
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings
.claude/

# Per-machine training paths (copy from training_paths.example.json)
data/training_paths.local.json

# Managed training control directories (plan, authorization, segment ledgers)
data/managed_runs/

# ChromaDB data (generated at runtime)
data/chroma/

# Runtime and imported game records — readers scan these trees recursively
data/games/**/*.jsonl
data/ai_games/**/*.jsonl
data/human_games/**/*.jsonl
data/human_games/imported.json
data/game_count.json
data/bad_moves.json

# Player profiles — personal data, not shared
data/players/

# LLM session narratives — personal data
data/session_memory/

# Local runtime logs under data/logs (keep directory via .gitkeep)
data/logs/**
!data/logs/.gitkeep

# HumanDB — large SQLite files built locally
data/human_db.sqlite
data/human_db.sqlite-shm
data/human_db.sqlite-wal
data/specialist_db*.sqlite
data/specialist_db*.sqlite-shm
data/specialist_db*.sqlite-wal
*.sqlite-journal

# Endgame retrograde tables and fullgame position DB — built locally, can be hundreds of MB
data/endgame/*.wdl
data/endgame/*.bin
data/endgame/fullgame.bin

# Evolution weight checkpoints — only keep best.json
data/weights/checkpoint_*.json
data/weights/era_best_*.json
data/weights/evolution_log.jsonl
data/weights/personalities/

# Backup snapshots
data/backups/

# Value net backups / pre-retrain snapshots
data/value_net*.bak*
data/value_net-*.npz

# Learned AI artifacts (keep dirs via .gitkeep)
# Smoke outputs, managed segments, and s_gen_v2_sector_corrected remain ignored
# under the checkpoints/** rule below; only reviewed historical shareable
# specialist/generalist *.pt trees are re-included.
learned_ai/checkpoints/**
!learned_ai/checkpoints/
!learned_ai/checkpoints/.gitkeep
!learned_ai/checkpoints/stage0/
!learned_ai/checkpoints/stage0/best.pt
!learned_ai/checkpoints/stage1/
!learned_ai/checkpoints/stage1/best.pt
# v2 specialist + generalist checkpoints — tracked so models can be shared
!learned_ai/checkpoints/scaffolded/
!learned_ai/checkpoints/scaffolded/s_open_v2/
!learned_ai/checkpoints/scaffolded/s_open_v2/*.pt
!learned_ai/checkpoints/scaffolded/s_mid_v2/
!learned_ai/checkpoints/scaffolded/s_mid_v2/*.pt
!learned_ai/checkpoints/scaffolded/s_end_v2/
!learned_ai/checkpoints/scaffolded/s_end_v2/*.pt
!learned_ai/checkpoints/scaffolded/s_gen_v2/
!learned_ai/checkpoints/scaffolded/s_gen_v2/*.pt
learned_ai/logs/*
!learned_ai/logs/.gitkeep
learned_ai/self_play_games/*
!learned_ai/self_play_games/.gitkeep

# Collaboration / draft docs — not for public repo
Sanmill_Collab.md

# OS
.DS_Store
Thumbs.db

# Keep directory structure for fresh installs (gitkeep files are committed)
!data/games/.gitkeep
!data/ai_games/.gitkeep
!data/human_games/.gitkeep
!data/session_memory/.gitkeep
!data/players/.gitkeep
!data/endgame/.gitkeep
!data/backups/.gitkeep
!data/logs/.gitkeep
